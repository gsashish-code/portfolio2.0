{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "allowArbitraryExtensions": true,
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Path aliases */
    "paths": {
      "#animations/*": ["./src/animations/*"],
      "#app/*": ["./src/app/*"],
      "#assets/*": ["./src/assets/*"],
      "#components/*": ["./src/components/*"],
      "#core/*": ["./src/core/*"],
      "#database": ["./src/database.ts"],
      "#features/*": ["./src/features/*"],
      "#hoc/*": ["./src/hoc/*"],
      "#hooks/*": ["./src/hooks/*"],
      "#lib/*": ["./src/lib/*"],
      "#routes/*": ["./src/routes/*"],
      "#services/*": ["./src/services/*"],
      "#store/*": ["./src/store/*"],
      "#stores/*": ["./src/stores/*"],
      "#test/*": ["./src/test/*"],
      "#types/*": ["./src/types/*"],
      "#utils/*": ["./src/utils/*"],
      "#windows/*": ["./src/windows/*"],
      "#workers/*": ["./src/workers/*"]
    },

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
